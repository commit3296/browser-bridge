{
  "name": "browser-bridge",
  "private": true,
  "version": "0.1.3",
  "description": "Chrome-first browser migration extension for encrypted bookmarks, cookies, and extension inventory transfers.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "migration",
    "cookies",
    "bookmarks",
    "wxt",
    "react"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wxt --host 0.0.0.0",
    "dev:chrome": "npm run dev:chrome:open",
    "dev:chrome:open": "node scripts/ensure-dev-profile.mjs && wxt --browser chrome --host 0.0.0.0",
    "dev:chrome:fresh": "node scripts/reset-dev-profile.mjs && npm run dev:chrome:open",
    "build": "wxt build",
    "build:chrome": "wxt build --browser chrome",
    "build:firefox": "wxt build --browser firefox",
    "build:edge": "wxt build --browser edge",
    "zip": "wxt zip --browser chrome",
    "zip:firefox": "wxt zip --browser firefox",
    "compile": "tsc --noEmit",
    "typecheck": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "npm run build:chrome && playwright test",
    "test:e2e:headed": "BROWSER_BRIDGE_E2E_HEADED=1 npm run test:e2e",
    "qa:chrome": "BROWSER_BRIDGE_E2E_HEADED=1 npm run test:e2e"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@wxt-dev/module-react": "^1.2.2",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wxt": "^0.20.26"
  },
  "overrides": {
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1",
    "undici": "^7.28.0",
    "esbuild": "^0.28.1",
    "fx-runner": "^1.5.0"
  }
}
